def example_payloads() -> list[dict[str, str]]:
    examples = []
    infiles_root = APP_ROOT / "share" / "infiles"
    if not infiles_root.exists():
        infiles_root = APP_ROOT / "infiles"
    for path in sorted(infiles_root.glob("*.inp")):
        content = path.read_text(encoding="utf-8", errors="replace")
        summary = next((line.strip("! ").strip() for line in content.splitlines() if line.strip().startswith("!") and "----" not in line), path.stem)
        examples.append({"name": path.name, "path": f"infiles/{path.name}", "summary": summary, "content": content})
    return examples


def contract() -> dict[str, Any]:
    return {
        "analysis_id": "mc-single-arm",
        "name": "Hall C mc-single-arm",
        "version": "container-contract-v1",
        "image_digest": "",
        "input_schema": INPUT_SCHEMA,
        "examples": example_payloads(),
        "run": {
            "command": "mc-single-arm-run --data-root /data --basename <stem>",
            "mounts": [{"path": "/data", "mode": "rw", "description": "Contains infiles, outfiles, runout, and worksim."}],
            "input_filename": "infiles/<basename>.inp",
            "seed_control": {
                "mode": "runner_blocked",
                "user_settable": False,
                "description": "hallc-mc-runner does not expose a seed field for mc-single-arm. Manual mc-single-arm-run use may pass --seed; otherwise mc-single-arm chooses a clock-time seed and prints the actual seed in the run log.",
                "log_pattern": r"Starting random number seed:\s*(\d+)",
            },
            "overwrite_policy": {
                "mode": "prompt_or_force",
                "description": "Existing runout/outfiles/worksim artifacts are never overwritten without an interactive confirmation or --force.",
            },
        },
        "outputs": [
            {"key": "rootfile", "path": "worksim/<basename>.root", "regenerable": True},
            {"key": "runout", "path": "runout/<basename>.out", "regenerable": True},
            {"key": "outfile", "path": "outfiles/<basename>.out", "regenerable": True},
        ],
    }


def to_yaml(value: Any, indent: int = 0) -> str:
    pad = " " * indent
    if isinstance(value, dict):
        lines = []
        for key, item in value.items():
            if isinstance(item, (dict, list)):
                lines.append(f"{pad}{key}:")
                lines.append(to_yaml(item, indent + 2))
            else:
                lines.append(f"{pad}{key}: {json.dumps(item)}")
        return "\n".join(lines)
    if isinstance(value, list):
        lines = []
        for item in value:
            if isinstance(item, (dict, list)):
                lines.append(f"{pad}-")
                lines.append(to_yaml(item, indent + 2))
            else:
                lines.append(f"{pad}- {json.dumps(item)}")
        return "\n".join(lines)
    return f"{pad}{json.dumps(value)}"


def main() -> int:
    parser = argparse.ArgumentParser(description="mc-single-arm container contract")
    subparsers = parser.add_subparsers(dest="command", required=True)
    describe = subparsers.add_parser("describe", help="Emit the analysis contract.")
    describe.add_argument("--format", choices=("json", "yaml"), default="yaml")
    args = parser.parse_args()

    payload = contract()
    if args.format == "json":
        print(json.dumps(payload, indent=2))
    else:
        print(to_yaml(payload))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
